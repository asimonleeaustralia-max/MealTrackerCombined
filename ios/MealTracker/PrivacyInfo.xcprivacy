<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- This app does not track users -->
    <key>NSPrivacyTracking</key>
    <false/>
    
    <!-- No tracking domains -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    
    <!-- No data collected or transmitted -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>
    
    <!-- Required Reason API usage declarations -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- File timestamp access (Core Data, file system) -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1: Access file timestamps for app functionality -->
                <string>C617.1</string>
            </array>
        </dict>
        
        <!-- User defaults access (app settings) -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: User preferences and settings -->
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
